[
	{
		"label": "Debug native binary",
		"build": {
			"command": "make",
			"args": [
				"debug",
				"-B",
				"O_DEBUG=1"
			],
			"cwd": "$ZED_WORKTREE_ROOT",
			"shell": {
				"with_arguments": {
					"program": "/bin/sh",
					"args": []
				}
			}
		},
		"program": "$ZED_WORKTREE_ROOT/gitm",
		"args": [
			"--log-level",
			"debug"
		],
		"request": "launch",
		"adapter": "CodeLLDB"
	}
]
